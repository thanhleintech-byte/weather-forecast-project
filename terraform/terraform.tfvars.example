# Copy this file to terraform.tfvars and fill in real values before running.
# NEVER commit terraform.tfvars to source control — add it to .gitignore.

aws_region  = "us-east-1"
environment = "production"

# VPC
vpc_cidr             = "10.0.0.0/16"
public_subnet_cidrs  = ["10.0.1.0/24", "10.0.2.0/24"]
private_subnet_cidrs = ["10.0.3.0/24", "10.0.4.0/24"]
single_nat_gateway   = false   # set true to reduce cost in non-prod

# EKS
kubernetes_version = "1.29"
node_instance_type = "t3.medium"
node_min_size      = 2
node_max_size      = 10
node_desired_size  = 2

# CloudWatch
log_retention_days    = 30
error_alarm_threshold = 10

# Lambda Authorizer
# Create the secret first:
#   aws secretsmanager create-secret \
#     --name "max-weather/jwt-secret" \
#     --secret-string "$(openssl rand -base64 32)"
# Then paste the ARN below.
jwt_secret_arn = "arn:aws:secretsmanager:us-east-1:123456789012:secret:max-weather/jwt-secret-XXXXXX"
