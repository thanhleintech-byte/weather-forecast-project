# Single source of truth for all secrets in this project.
#
#   1. cp credentials.local.env.example credentials.local.env
#   2. Fill in real values (gitignored — never commit)
#   3. source credentials.local.env
#   4. Then run terraform stages in order: network → eks → api-gateway → argocd
#
# Your LOCAL aws CLI credentials (used by terraform / kubectl) come from
# `aws configure` or AWS_PROFILE — not from this file.
# Jenkins's AWS access in the cluster is via IRSA — also not from this file.

# ─── GitHub (Argo CD repo sync + Jenkins clone) ───────────────────────────
export TF_VAR_github_repo_url="https://github.com/<you>/<repo>.git"
export TF_VAR_github_username="<your-github-login>"
export TF_VAR_github_pat="ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# ─── JWT signing key ──────────────────────────────────────────────────────
# Plaintext. The api-gateway stage writes it to AWS Secrets Manager (Lambda
# reads from there); the argocd stage writes the same value into a k8s
# Secret (FastAPI pod reads from there). One value, two destinations.
# Generate with: openssl rand -base64 48
export TF_VAR_jwt_secret_value="REPLACE_WITH_RANDOM_48_BYTES"

# ─── OAuth2 client_credentials (for /token) ───────────────────────────────
export TF_VAR_oauth_client_id="max-weather-client"
export TF_VAR_oauth_client_secret="REPLACE_WITH_STRONG_RANDOM"

# ─── Argo CD admin (UI/CLI login) ─────────────────────────────────────────
# Plaintext — terraform bcrypt-hashes it before passing to the helm release.
export TF_VAR_argocd_admin_password="REPLACE_WITH_STRONG_PASSWORD"

# ─── Jenkins admin (UI login) ─────────────────────────────────────────────
# Plaintext — written to a k8s Secret the Jenkins helm chart references via
# controller.admin.existingSecret.
export TF_VAR_jenkins_admin_password="REPLACE_WITH_STRONG_PASSWORD"

# ─── Cloudflare (DNS / proxy management — manual use) ─────────────────────
# Not consumed by terraform. Kept here so all secrets live in one place.
export CLOUDFLARE_API_TOKEN="cfut_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# ─── Non-secret config (handy to keep alongside) ──────────────────────────
export AWS_REGION="ap-south-1"
export EKS_CLUSTER_NAME="max-weather-production"
export TF_VAR_app_host="max-weather.example.com"
# Public Argo CD UI hostname. Leave blank to skip ingress (port-forward only).
export TF_VAR_argocd_hostname="argocd.example.com"
