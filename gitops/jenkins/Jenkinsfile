pipeline {
    agent {
        kubernetes {
            yaml """
apiVersion: v1
kind: Pod
spec:
  serviceAccountName: jenkins
  containers:
  - name: jnlp
    image: jenkins/inbound-agent:latest-jdk17
    resources:
      requests:
        cpu: 256m
        memory: 512Mi
  - name: python
    image: python:3.12-slim
    command: ["sleep", "infinity"]
    resources:
      requests:
        cpu: 256m
        memory: 512Mi
  - name: kaniko
    image: gcr.io/kaniko-project/executor:debug
    command: ["sleep", "infinity"]
    env:
    - name: AWS_SDK_LOAD_CONFIG
      value: "true"
    resources:
      requests:
        cpu: 512m
        memory: 1Gi
  - name: aws-kubectl
    image: alpine/k8s:1.32.3
    command: ["sleep", "infinity"]
    securityContext:
      runAsUser: 0
    resources:
      requests:
        cpu: 128m
        memory: 256Mi
"""
        }
    }

    environment {
        AWS_REGION    = 'ap-south-1'
        ECR_REGISTRY  = credentials('ecr-registry-url')
        IMAGE_NAME    = 'max-weather'
        IMAGE_TAG     = "${env.BUILD_NUMBER}"
        EKS_CLUSTER   = 'max-weather-production'
        PRODUCTION_NS = 'max-weather'
    }

    options {
        buildDiscarder(logRotator(numToKeepStr: '20'))
        timeout(time: 30, unit: 'MINUTES')
        disableConcurrentBuilds()
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
                script {
                    env.GIT_COMMIT_SHORT = sh(script: "git rev-parse --short HEAD", returnStdout: true).trim()
                    env.FULL_IMAGE   = "${ECR_REGISTRY}/${IMAGE_NAME}:${IMAGE_TAG}"
                    env.LATEST_IMAGE = "${ECR_REGISTRY}/${IMAGE_NAME}:latest"
                }
            }
        }

        stage('Test') {
            steps {
                container('python') {
                    dir('app') {
                        sh '''
                            python3 -m venv .venv
                            . .venv/bin/activate
                            pip install -r requirements.txt -q
                            python -m pytest tests/ -v --tb=short --junitxml=../test-results/results.xml
                        '''
                    }
                }
            }
            post {
                always {
                    junit allowEmptyResults: true, testResults: 'test-results/results.xml'
                }
            }
        }

        stage('Build & Push') {
            steps {
                container('kaniko') {
                    sh """
                        mkdir -p /kaniko/.docker
                        echo '{"credHelpers":{"${ECR_REGISTRY}":"ecr-login"}}' > /kaniko/.docker/config.json
                        /kaniko/executor \
                            --context=\${WORKSPACE}/app \
                            --dockerfile=\${WORKSPACE}/app/Dockerfile \
                            --destination=${env.FULL_IMAGE} \
                            --destination=${env.LATEST_IMAGE} \
                            --label git-commit=${env.GIT_COMMIT_SHORT} \
                            --label build-number=${IMAGE_TAG}
                    """
                }
            }
        }

        stage('Deploy to Production') {
            when { branch 'main' }
            steps {
                container('aws-kubectl') {
                    sh """
                        aws eks update-kubeconfig \
                            --region ${AWS_REGION} \
                            --name ${EKS_CLUSTER}
                        kubectl set image deployment/max-weather \
                            max-weather=${env.FULL_IMAGE} \
                            -n ${PRODUCTION_NS}
                        kubectl rollout status deployment/max-weather \
                            -n ${PRODUCTION_NS} \
                            --timeout=180s
                    """
                }
            }
        }

    }

    post {
        always {
            cleanWs()
        }
    }
}
